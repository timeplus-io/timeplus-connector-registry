# Timeplus Connector Registry Configuration
# Copy this file to .env and customize for your environment

# Application
APP_NAME="Timeplus Connector Registry"
DEBUG=false
APP_VERSION="0.2.0"

# Server
HOST=0.0.0.0
PORT=8000

# Database (embedded SQLite - no external database required)
DATABASE_URL=sqlite+aiosqlite:///./registry.db

# Security
# IMPORTANT: Change this to a random string in production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-in-production-use-a-long-random-string

# JWT settings
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# CORS
# Either JSON array or comma-separated list.
CORS_ORIGINS=["http://localhost:8000","http://127.0.0.1:8000"]
CORS_ALLOW_CREDENTIALS=false

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Storage (for future package file storage)
STORAGE_PATH=./storage

# Rate limiting (requests per hour)
# Values must be positive integers (> 0).
RATE_LIMIT_ANONYMOUS=60
RATE_LIMIT_AUTHENTICATED=1000
RATE_LIMIT_WINDOW_SECONDS=3600
# If true, anonymous rate-limit keys use X-Forwarded-For / X-Real-IP when present.
# Enable only behind a trusted reverse proxy.
RATE_LIMIT_USE_FORWARDED_FOR=false
